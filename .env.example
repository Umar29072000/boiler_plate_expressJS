# Application
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/express_boilerplate

# JWT Configuration
# Access token: short-lived for API requests (e.g., 15m, 30m, 1h)
# Refresh token: long-lived for token refresh (in days, e.g., 7, 30)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Email Configuration
# For Gmail: Use 'gmail' and generate app password (https://myaccount.google.com/apppasswords)
# For other providers: Use SMTP settings
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourapp.com
EMAIL_FROM_NAME=Express Boilerplate

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_ENABLED=true

# Cache Configuration
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
